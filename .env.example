# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Optional: Stripe Payment Link — customer chooses amount at checkout
# Create in Stripe Dashboard: Product → Payment links → Add link. Then set the URL here.
# NEXT_PUBLIC_STRIPE_DONATION_LINK=https://buy.stripe.com/xxxxx
NEXT_PUBLIC_STRIPE_DONATION_LINK=

# Site URL (for redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Feature flags
# When true in production, all app flows (signup, dashboard, etc.) can be visually pointed to the waitlist instead.
# Locally you can leave this false to use the full app.
NEXT_PUBLIC_WAITLIST_ONLY=false
WAITLIST_ONLY=false

# Ollama (local AI for resume analysis) - optional, defaults to localhost:11434
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3
